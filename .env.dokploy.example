# Open Wearables — Environment pour l'app Dokploy (à coller dans l'onglet Environment).
# Ce fichier est un EXEMPLE (placeholders). Les vraies valeurs/secrets vont dans Dokploy,
# jamais dans Git. DB_HOST/REDIS_HOST sont fixés par le compose (db/redis internes).

#--- APP ---#
ENVIRONMENT=production
API_PORT=8000
API_BASE_URL=https://wearables-api.leadyoupro.com
FRONTEND_URL=https://wearables.leadyoupro.com
CORS_ORIGINS=["https://wearables.leadyoupro.com"]
VITE_API_URL=https://wearables-api.leadyoupro.com

#--- DB (interne) ---#
DB_NAME=open-wearables
DB_USER=open-wearables
DB_PASSWORD=__GENERER__
DB_PORT=5432

#--- REDIS (interne) ---#
REDIS_PORT=6379
REDIS_DB=0

#--- AUTH / ADMIN ---#
SECRET_KEY=__GENERER__
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=__GENERER__

#--- SENTRY (off ou pointer vers GlitchTip) ---#
SENTRY_ENABLED=False
SENTRY_DSN=""

#--- WEBHOOKS (Svix interne) ---#
SVIX_SERVER_URL=http://svix-server:8071

#--- SYNC ---#
HISTORICAL_SYNC_ON_CONNECT=true
INGEST_WORKOUT_SAMPLES=false
STORE_FIT_FILES=false

#--- EMAIL (Resend) — optionnel ---#
RESEND_API_KEY=
EMAIL_FROM_ADDRESS="onboarding@resend.dev"
EMAIL_FROM_NAME="Open Wearables"

#--- AWS — optionnel (stockage raw payloads) ---#
AWS_BUCKET_NAME=open-wearables
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3

#--- PROVIDERS OAuth — plateforme nue : laisser vide, brancher plus tard ---#
# GARMIN_CLIENT_ID=...    GARMIN_CLIENT_SECRET=...
# OURA_CLIENT_ID=...      OURA_CLIENT_SECRET=...
# WHOOP_CLIENT_ID=...     WHOOP_CLIENT_SECRET=...
# POLAR_CLIENT_ID=...     POLAR_CLIENT_SECRET=...
# FITBIT_CLIENT_ID=...    FITBIT_CLIENT_SECRET=...
# STRAVA_CLIENT_ID=...    STRAVA_CLIENT_SECRET=...   STRAVA_WEBHOOK_VERIFY_TOKEN=...
# SUUNTO_CLIENT_ID=...    SUUNTO_CLIENT_SECRET=...   SUUNTO_SUBSCRIPTION_KEY=...
# ULTRAHUMAN_CLIENT_ID=... ULTRAHUMAN_CLIENT_SECRET=...
